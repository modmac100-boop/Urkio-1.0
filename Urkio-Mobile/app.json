{
  "expo": {
    "name": "Urkio-Mobile",
    "slug": "Urkio-Mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "urkiomobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "associatedDomains": [
        "applinks:urkio.com",
        "applinks:urkio-65fb0.firebaseapp.com",
        "applinks:urkio-65fb0.web.app"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "urkio.com",
              "pathPrefix": "/__/auth"
            },
            {
              "scheme": "https",
              "host": "urkio-65fb0.firebaseapp.com",
              "pathPrefix": "/__/auth"
            },
            {
              "scheme": "https",
              "host": "urkio-65fb0.web.app",
              "pathPrefix": "/__/auth"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "updates": {
      "url": "https://u.expo.dev/[REPLACE_WITH_YOUR_PROJECT_ID]"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "[REPLACE_WITH_YOUR_PROJECT_ID]"
      },
      "firebase": {
        "projectId": "urkio-65fb0"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}