rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
    }
    
    function hasRole(roles) {
      return isSignedIn() && getUserData().role in roles;
    }

    // Profiles: Users can manage their own, Admins can manage all.
    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if hasRole(['BOARD', 'FOUNDER']) || 
                    (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isVerified', 'role', 'verificationStatus']));
      allow delete: if hasRole(['FOUNDER']);
    }

    // Posts: Owners can create/edit/delete, anyone signed in can read.
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.authorId == request.auth.uid || hasRole(['BOARD', 'FOUNDER']));
      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || hasRole(['FOUNDER']));
      
      // Data validation for posts
      allow write: if request.resource.data.content is string && 
                      request.resource.data.content.size() <= 5000;
    }

    // Reflections subcollection
    match /users/{userId}/reflections/{reflectionId} {
      allow read, write: if isOwner(userId);
    }
    
    // Group subcollection access for specialists/doctors
    match /{path=**}/reflections/{reflectionId} {
      allow read: if hasRole(['SPECIALIST', 'DOCTOR']);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}