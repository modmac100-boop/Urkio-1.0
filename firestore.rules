rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /profiles/{userId} {
      allow read: if request.auth != null;
      
      // Admins can update anything (including isVerified and role)
      allow update: if request.auth != null && 
                     get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role in ['BOARD', 'FOUNDER'];
                     
      // Users can update their own profile, but NOT their verification status or role
      allow update: if request.auth != null && request.auth.uid == userId &&
                     (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isVerified', 'role']));
                     
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/reflections/{reflectionId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /{path=**}/reflections/{reflectionId} {
      allow read: if request.auth != null && 
                   get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role in ['SPECIALIST', 'DOCTOR'];
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}